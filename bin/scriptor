#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Scriptor CLI entry point.
 *
 * Today only knows the `install` subcommand. Designed to grow more
 * subcommands later (`user:add`, `user:passwd`, `cache:clear`, …);
 * the dispatch stays a simple switch until that list outgrows it,
 * at which point Symfony Console becomes worth its dependency cost.
 *
 * Security guarantee G1 from docs/scriptor-install-cli-plan.md: this
 * file refuses to run under any SAPI but `cli`. Belt-and-suspenders
 * to the webroot layout (bin/ lives outside public/), so a misconfig
 * that exposes bin/ over HTTP still can't run install via PHP-FPM.
 */

if (\PHP_SAPI !== 'cli') {
    \fwrite(\STDERR, "bin/scriptor only runs from the command line.\n");
    exit(3);
}

$root = \dirname(__DIR__);
require $root . '/vendor/autoload.php';

$args = $argv;
\array_shift($args); // drop the script name
$command = $args[0] ?? '';
\array_shift($args);

switch ($command) {
    case 'install':
        $options = parse_options($args);
        if (isset($options['help'])) {
            print_install_help();
            exit(0);
        }
        $console = new \Scriptor\Boot\Cli\Console();
        $prompt  = new \Scriptor\Boot\Cli\PasswordPrompt($console);
        $cmd     = new \Scriptor\Boot\Cli\InstallCommand($root, $console, $prompt);
        exit($cmd->run($options));

    case 'plugin:list':
        $options = parse_options($args);
        if (isset($options['help'])) {
            print_plugin_list_help();
            exit(0);
        }
        $console = new \Scriptor\Boot\Cli\Console();
        $cmd     = new \Scriptor\Boot\Cli\PluginListCommand($root, $console);
        exit($cmd->run());

    case 'plugin:install':
        $options = parse_options($args);
        if (isset($options['help'])) {
            print_plugin_install_help();
            exit(0);
        }
        $positional = parse_positional($args);
        $console    = new \Scriptor\Boot\Cli\Console();
        $cmd        = new \Scriptor\Boot\Cli\PluginInstallCommand($root, $console);
        exit($cmd->run($options, $positional));

    case 'plugin:uninstall':
        $options = parse_options($args);
        if (isset($options['help'])) {
            print_plugin_uninstall_help();
            exit(0);
        }
        $positional = parse_positional($args);
        $console    = new \Scriptor\Boot\Cli\Console();
        $cmd        = new \Scriptor\Boot\Cli\PluginUninstallCommand($root, $console);
        exit($cmd->run($options, $positional));

    case '':
    case 'help':
    case '--help':
    case '-h':
        print_top_help();
        exit($command === '' ? 1 : 0);

    default:
        \fwrite(\STDERR, "Unknown command: {$command}\n\n");
        print_top_help();
        exit(1);
}

/**
 * @param list<string> $args
 * @return array<string, string|bool>
 */
function parse_options(array $args): array
{
    $opts = [];
    foreach ($args as $arg) {
        if ($arg === '--yes' || $arg === '-y') {
            $opts['yes'] = true;
            continue;
        }
        if ($arg === '--help' || $arg === '-h') {
            $opts['help'] = true;
            continue;
        }
        if (\str_starts_with($arg, '--')) {
            $body = \substr($arg, 2);
            $eqPos = \strpos($body, '=');
            if ($eqPos === false) {
                // Treat boolean flag.
                $opts[$body] = true;
                continue;
            }
            $name  = \substr($body, 0, $eqPos);
            $value = \substr($body, $eqPos + 1);
            $opts[$name] = $value;
            continue;
        }
        // Bare positional args returned via parse_positional(); ignored here.
    }
    return $opts;
}

/**
 * Return positional (non `--…`) arguments in order.
 *
 * @param list<string> $args
 * @return list<string>
 */
function parse_positional(array $args): array
{
    $positional = [];
    foreach ($args as $arg) {
        if (\str_starts_with($arg, '-')) {
            continue;
        }
        $positional[] = $arg;
    }
    return $positional;
}

function print_top_help(): void
{
    echo <<<'TXT'
Scriptor CLI.

Usage:
  bin/scriptor <command> [options]

Commands:
  install            Seed a fresh Scriptor database (Pages, Users, admin, Home).
  plugin:list        Show discovered Scriptor plugins and their lifecycle state.
  plugin:install     Run a lifecycle plugin's install() hook + mark it installed.
  plugin:uninstall   Run a lifecycle plugin's uninstall() hook + clear state.
  help               Show this message.

Run `bin/scriptor <command> --help` for command-specific options.

TXT;
}

function print_plugin_list_help(): void
{
    echo <<<'TXT'
Show installed and discovered Scriptor plugins.

Usage:
  bin/scriptor plugin:list [options]

Options:
  --help, -h    Show this message.

Three kinds of rows appear:

  - stateless / discovered      plain Plugin implementor, no lifecycle state
  - lifecycle / pending install LifecyclePlugin not yet installed via this CLI
  - lifecycle / installed       LifecyclePlugin tracked in data/plugin-states.json
  - lifecycle / ORPHAN          state.json entry without a discovered package
                                (the operator ran `composer remove` without a
                                matching `plugin:uninstall` first)

The command reads vendor/composer/installed.json and the plugin state
file; it does not load or boot any plugin. Safe to run before
`bin/scriptor install` on a fresh checkout.

TXT;
}

function print_plugin_install_help(): void
{
    echo <<<'TXT'
Invoke the install() hook of a lifecycle plugin.

Usage:
  bin/scriptor plugin:install <package>
  bin/scriptor plugin:install --all

Options:
  --all         Install every discovered lifecycle plugin not yet installed.
  --force       Re-run install() even if the package is already marked installed.
  --help, -h    Show this message.

Bootstraps the iManager container, instantiates the plugin's class,
and calls `LifecyclePlugin::install()` exactly once. On success the
package is recorded in `data/plugin-states.json`; on failure the
state file is left unchanged so the operator can fix and retry.

Refuses to run when:
  - The package is not discovered (typo / not composer-required).
  - The plugin class is a plain Plugin (no lifecycle hook to call —
    stateless plugins are loaded automatically per request).
  - The package is already installed (use --force to override).

TXT;
}

function print_plugin_uninstall_help(): void
{
    echo <<<'TXT'
Invoke the uninstall() hook of a lifecycle plugin and clear its state entry.

Usage:
  bin/scriptor plugin:uninstall <package> [options]

Options:
  --purge-data            Tell the plugin to also remove row values it
                          owns from items.data. Default: data is preserved
                          on the assumption that a future reinstall might
                          pick it back up.
  --force-state-clear     Drop the state entry without invoking
                          uninstall(). Use when the plugin's uninstall()
                          itself is broken or the class is gone.
  --help, -h              Show this message.

After this command succeeds, run `composer remove <package>` to remove
the package from vendor/. The two-step sequence (CLI first, composer
second) means the plugin's uninstall() runs while its class is still
loadable.

TXT;
}

function print_install_help(): void
{
    echo <<<'TXT'
Seed a fresh Scriptor database.

Usage:
  bin/scriptor install [options]

Options:
  --password=<value>   Admin password (overrides SCRIPTOR_ADMIN_PASSWORD env).
  --username=<name>    Admin username (default: admin).
  --email=<addr>       Admin email (default: admin@example.com).
  --db=<path>          Database file path (default: data/imanager.db).
  --yes, -y            Skip the "type INSTALL to proceed" prompt. Required
                       when stdin is not a TTY.
  --help, -h           Show this message.

Password sources (first match wins):
  1. --password=...
  2. $SCRIPTOR_ADMIN_PASSWORD
  3. Interactive prompt (requires a TTY).

The command refuses to run if a Pages category already exists in the
database. To start over, delete the database file explicitly.

TXT;
}
